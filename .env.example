# Copy this file to .env for local development (never commit .env)
# Set these same keys in Render's Environment Variables dashboard

DB_HOST=your-mysql-host
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASS=your-database-password

# URL of the maze-escape-ml Render service (set after deploying ML service)
ML_API_URL=https://maze-escape-ml.onrender.com
